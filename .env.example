COMPOSE_PROJECT_NAME=yazoo
APP_PORT=8000
FRONTEND_PORT=4173
LAN_HOST=localhost

# Exemple local sans secrets reels. Ne jamais publier .env.
# MySQL Docker publie le port local 3307 vers le port conteneur 3306.
APP_KEY=

DB_DATABASE=yazoo
DB_PUBLISHED_PORT=3307
DB_USERNAME=yazoo
DB_PASSWORD=
DB_ROOT_PASSWORD=

REDIS_PASSWORD=

SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
SONAR_DB_NAME=sonarqube
SONAR_DB_USERNAME=sonar
SONAR_DB_PASSWORD=

# Monitoring externe optionnel, a renseigner plus tard via Azure App Settings/GitHub Secrets.
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
APPINSIGHTS_CONNECTION_STRING=
