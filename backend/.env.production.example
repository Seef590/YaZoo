APP_NAME=YaZoo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://<azure-webapp-name>.azurewebsites.net
APP_FORCE_HTTPS=true

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=8

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
MONITORING_LOG_CHANNEL=observability
MONITORING_LOG_LEVEL=warning
MONITORING_LOG_DAYS=14
FRONTEND_MONITORING_LOG_CHANNEL=frontend
FRONTEND_MONITORING_LOG_LEVEL=error
FRONTEND_MONITORING_LOG_DAYS=14

DB_CONNECTION=mysql
DB_HOST=<mysql-server-name>.mysql.database.azure.com
DB_PORT=3306
DB_DATABASE=yazoo
DB_USERNAME=<mysql-admin-user>
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

FILESYSTEM_DISK=public
MEDIA_STORAGE_DRIVER=filesystem
MEDIA_FILESYSTEM_DISK=public
MEDIA_MONGODB_ENABLED=false
MEDIA_MONGODB_URI=
MEDIA_MONGODB_DATABASE=yazoo
MEDIA_MONGODB_BUCKET=uploads
MEDIA_BACKUP_ENABLED=false
MEDIA_BACKUP_DISK=backups
MEDIA_BACKUP_SCHEDULE=03:30
MEDIA_BACKUP_KEEP_DAYS=7

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_SCHEME=tls
REDIS_HOST=<redis-name>.redis.cache.windows.net
REDIS_PASSWORD=
REDIS_PORT=6380
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
FRONTEND_URL=https://<static-web-app-name>.azurestaticapps.net
SANCTUM_STATEFUL_DOMAINS=<static-web-app-name>.azurestaticapps.net
CORS_ALLOWED_ORIGINS=https://<static-web-app-name>.azurestaticapps.net
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
