APP_NAME=YaZoo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FORCE_HTTPS=false
ADMIN_BOOTSTRAP_ENABLED=false

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
MONITORING_LOG_CHANNEL=observability
MONITORING_LOG_LEVEL=warning
MONITORING_LOG_DAYS=14
FRONTEND_MONITORING_LOG_CHANNEL=frontend
FRONTEND_MONITORING_LOG_LEVEL=error
FRONTEND_MONITORING_LOG_DAYS=14
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
APPINSIGHTS_CONNECTION_STRING=

# Relationnel et donnees sensibles: MySQL
# Depuis Windows avec le MySQL Docker publie: DB_HOST=127.0.0.1 et DB_PORT=3307.
# Depuis Docker Compose: DB_HOST=mysql et DB_PORT=3306.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=yazoo
DB_USERNAME=root
DB_PASSWORD=
DB_ROOT_PASSWORD=
# Docker compose:
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=yazoo
# DB_USERNAME=yazoo
# DB_PASSWORD=
LEGACY_SQLITE_DATABASE=database/database.sqlite

SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
FILESYSTEM_DISK=public
# Medias: "filesystem" reste le mode local par defaut.
# MongoDB GridFS est optionnel et reserve au developpement/experimentation locale.
# Ne pointez pas une production Azure vers mongodb://127.0.0.1:27017.
# Pour une production durable, planifier Azure Blob Storage ou un volume persistant
# avant d'activer une migration de stockage media.
MEDIA_STORAGE_DRIVER=filesystem
MEDIA_FILESYSTEM_DISK=public
MEDIA_MONGODB_ENABLED=false
MEDIA_MONGODB_URI=
MEDIA_MONGODB_DATABASE=yazoo
MEDIA_MONGODB_BUCKET=uploads
MEDIA_BACKUP_ENABLED=false
MEDIA_BACKUP_DISK=backups
MEDIA_BACKUP_SCHEDULE=03:30
MEDIA_BACKUP_KEEP_DAYS=7
QUEUE_CONNECTION=redis

PAYMENT_DEFAULT_PROVIDER=manual_bank_transfer
PAYMENT_CURRENCY=MAD
PAYMENT_COMMISSION_RATE=0
PAYMENT_ACTIVE_TTL_MINUTES=30
CMI_ENABLED=false
CMI_MODE=sandbox
CMI_GATEWAY_URL=
CMI_CLIENT_ID=
CMI_STORE_KEY=
CMI_OK_URL=
CMI_FAIL_URL=
CMI_CALLBACK_URL=

LEGAL_ENTITY_NAME=YaZoo
LEGAL_STATUS=
LEGAL_ADDRESS=
LEGAL_ICE=
PRIVACY_CONTACT_EMAIL=privacy@example.com
DATA_CONTROLLER_NAME=YaZoo
DATA_RETENTION_DAYS=365
DATA_REQUEST_RESPONSE_DAYS=30

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/feed
GOOGLE_LOGIN_REDIRECT=http://localhost:5173/login
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
# Frontend statique Docker prod:
# FRONTEND_URL=http://localhost:4173
# SANCTUM_STATEFUL_DOMAINS=localhost:4173,127.0.0.1:4173
# CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
