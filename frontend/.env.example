VITE_APP_NAME=YaZoo
# Exemple local sans secrets reels. Ne jamais publier frontend/.env.
VITE_API_URL=http://localhost:8000/api
VITE_GOOGLE_AUTH_ENABLED=true
VITE_STORAGE_URL=http://localhost:8000/storage
VITE_REALTIME_ENABLED=false
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=127.0.0.1
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_MONITORING_ENABLED=false
VITE_MONITORING_ENDPOINT=http://localhost:8000/api/monitoring/frontend-error
VITE_SENTRY_DSN=
VITE_NOTIFICATIONS_POLL_MS=30000
# Frontend statique via Docker:
# VITE_API_URL=http://localhost:8000/api
# VITE_STORAGE_URL=http://localhost:8000/storage
