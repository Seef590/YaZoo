VITE_APP_NAME=YaZoo
VITE_API_URL=https://yazoo-api.azurewebsites.net/api
VITE_GOOGLE_AUTH_ENABLED=true
VITE_STORAGE_URL=https://yazoo-api.azurewebsites.net/storage
VITE_REALTIME_ENABLED=false
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=yazoo-api.azurewebsites.net
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
VITE_MONITORING_ENABLED=false
VITE_MONITORING_ENDPOINT=https://yazoo-api.azurewebsites.net/api/monitoring/frontend-error
VITE_NOTIFICATIONS_POLL_MS=30000
VITE_BUILD_SOURCEMAPS=false
